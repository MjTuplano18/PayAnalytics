# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Application
APP_NAME=PayAnalytics API
APP_VERSION=1.0.0
DEBUG=true

# Database (Neon PostgreSQL)
# Get this from your Neon dashboard -> Connection string
# Make sure to use the pooled connection string for production
DATABASE_URL=postgresql://neondb_owner:npg_tgUiByP90VDj@ep-ancient-cherry-adn2jhem-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT Authentication
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000"]
